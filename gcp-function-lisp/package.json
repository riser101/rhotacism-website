{
  "name": "lisp-speech-analyzer",
  "version": "1.0.0",
  "description": "GCP Cloud Function: combines per-word audio and analyzes sigmatism (lisp) with Gemini using client-side FFT metrics.",
  "main": "index.js",
  "scripts": {
    "start": "functions-framework --target=analyzeLispSpeech"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/functions-framework": "^3.4.0",
    "@google-cloud/storage": "^7.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "fluent-ffmpeg": "^2.1.2",
    "multer": "^1.4.5-lts.1",
    "undici": "^6.27.0"
  }
}
